ENVIRONMENT=development
LOG_LEVEL=INFO

# Object storage — same bucket the Rust backend uploads to.
S3_BUCKET=nutrilens-uploads
S3_REGION=auto
# Set for Cloudflare R2 or MinIO, e.g. https://<account>.r2.cloudflarestorage.com.
# Leave unset for AWS S3.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Experiment tracking (optional — leave unset to skip wandb logging).
WANDB_API_KEY=
WANDB_PROJECT=nutrilens
WANDB_ENTITY=

# Model registry prefix inside the object store.
MODEL_REGISTRY_PREFIX=models/

# Local paths (git-ignored).
DATA_DIR=data
RUNS_DIR=runs

# Inference server.
SERVE_HOST=0.0.0.0
SERVE_PORT=8000
# Shared secret the Rust backend sends as X-Internal-Secret. Required in non-dev.
SERVE_SHARED_SECRET=
