{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nutrilens.app/schemas/ml/inference_response.json",
  "title": "InferenceResponse",
  "description": "Shape the Rust backend re-emits and iOS consumes for plate + pour inference. Stable across plate and pour tasks; task-specific fields live under `task_extras`.",
  "type": "object",
  "required": ["schema_version", "task", "items", "overall_confidence"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "task": {"type": "string", "enum": ["plate", "pour"]},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "confidence"],
        "additionalProperties": false,
        "properties": {
          "label": {"type": "string"},
          "fdc_id": {"type": ["integer", "null"]},
          "grams": {"type": ["number", "null"], "minimum": 0},
          "kcal": {"type": ["number", "null"], "minimum": 0},
          "volume_ml": {"type": ["number", "null"], "minimum": 0},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "overall_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "followup_questions": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "task_extras": {
      "type": "object",
      "additionalProperties": true,
      "description": "Task-specific payload: e.g. segmentation polygon summaries for plate, per-frame ml curves for pour."
    },
    "model_version": {
      "type": "string",
      "description": "Semver of the model that produced this response, e.g. 'plate-0.1.0'."
    }
  }
}
